#
# General
#
COMPOSE_PROJECT_NAME=suricatoos

#
# SSL specific configuration
#
AUTHORITY_NAME=Suricatoos
AUTHORITY_PASSWORD=CHANGEME_ssl_password
COMPANY=Suricatoos
DOMAIN_NAME=suricatoos.example.com
COUNTRY_CODE=US
STATE=Georgia
CITY=Atlanta

#
# Database configurations
#
POSTGRES_DB=suricatoos
POSTGRES_USER=suricatoos
POSTGRES_PASSWORD=CHANGEME_strong_db_password
POSTGRES_PORT=5432
POSTGRES_HOST=db

#
# Celery Scaling Configurations
#
# MAX/MIN_CONCURRENCY: prefork pool do worker pesado de scan (main_scan_queue).
# Defaults conservadores p/ box pequeno (~4GB). Em hosts grandes suba (ex.: 80/10).
MAX_CONCURRENCY=4
MIN_CONCURRENCY=1
# SHARED_CONCURRENCY: greenlets do unico worker gevent que serve as 21 filas
# leves/IO-bound. Greenlets sao baratos (custo de RAM e o import do Django, nao
# por-greenlet), mas cada tool spawnado consome RAM real; em box pequeno mantenha
# baixo (10). Suba em hosts grandes.
SHARED_CONCURRENCY=10

#
# Capacity-proportional orchestration timers
#
# The scan DURATION timers (per-tool watchdog, Celery soft/hard limits, dir-fuzz
# budget, OSINT tool caps, the orchestration barrier and the hang-monitor stale
# window) are calibrated for the baseline 2-vCPU box. On a bigger host that runs
# heavier / more concurrent scans they legitimately take longer, so they are scaled
# UP UNIFORMLY by a single capacity factor F. Uniform scaling preserves the safety
# ordering (watchdog <= soft <= hard <= hang-stale, and dir-fuzz-budget < soft) at
# any F. F = clamp(detected_cpus / TIMER_BASELINE_CPUS, 1.0, MAX) — it only ever
# ENLARGES, never shrinks. On this 2-CPU box F == 1.0, so the timers are unchanged.
#
# TIMER_BASELINE_CPUS=2              # the box the absolute timers were calibrated on
# SURICATOOS_CAPACITY_FACTOR_MAX=8.0 # ceiling on F (never scale beyond 8x)
# SURICATOOS_CAPACITY_FACTOR=        # explicit float override; wins over CPU detection
#
# Per-timer env vars (COMMAND_EXEC_TIMEOUT, ORCHESTRATION_BARRIER_TIMEOUT,
# HANG_MONITOR_STALE_AFTER, CELERY_TASK_SOFT_TIME_LIMIT, CELERY_TASK_TIME_LIMIT) are
# still honored VERBATIM when set (an explicit env = an absolute operator value, not
# scaled). NOTE: docker-compose.yml currently sets ORCHESTRATION_BARRIER_TIMEOUT=7200
# explicitly, so the barrier stays 7200 (un-scaled) on every box; remove that compose
# line (or set it per-box) to let the barrier scale automatically with capacity.

#
# Secret scanning (optional)
# ggshield (GitGuardian) needs an API key. Leave blank to use gitleaks only.
# Get one at https://dashboard.gitguardian.com/api/personal-access-tokens
#
GITGUARDIAN_API_KEY=

#
# Suricatoos web interface super user (for non-interactive install)
#
DJANGO_SUPERUSER_USERNAME=suricatoos
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=CHANGEME_strong_admin_password

#
# API credential vault encryption key (urlsafe-base64 32-byte Fernet key).
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# If unset, derived from SECRET_KEY (a startup warning is logged).
#
RENGINE_VAULT_KEY=
