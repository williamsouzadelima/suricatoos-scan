#: scanEngine/templates/scanEngine/settings/proxy.html:42
msgid "You can enter as many proxies as you want, Suricatoos will <span class=\"text-primary\">randomly</span> pick one among them during the scan."
msgstr "Você pode inserir quantos proxies quiser; o Suricatoos escolherá <span class=\"text-primary\">aleatoriamente</span> um deles durante a varredura."

#: scanEngine/templates/scanEngine/settings/proxy.html:43
